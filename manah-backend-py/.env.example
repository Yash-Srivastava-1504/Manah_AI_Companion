PORT=3001
NODE_ENV=development

# ── Supabase JWT ───────────────────────────────────────────────────────────────
# Only required if your Supabase project still issues HS256 user tokens (legacy).
# New projects use RS256 + JWKS — verification happens automatically via the issuer URL.
# Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── JWT (legacy SQLite auth + WebSocket) ──────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_too_separate_secret_for_refresh_tokens
JWT_EXPIRES_IN=3600          # seconds (1 hour)
JWT_REFRESH_EXPIRES_IN=2592000  # seconds (30 days)

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=./data/manah.db

# ── OpenRouter (used when OPENROUTER_API_KEY is set and USE_MOCK_LLM != true) ─
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Manah

# ── Qubrid (fallback if OpenRouter key is empty) ──────────────────────────────
QUBRID_API_KEY=your_qubrid_api_key_here
QUBRID_BASE_URL=https://platform.qubrid.com/v1
QUBRID_MODEL=google/gemini-2.5-flash

# true = mock only. false = OpenRouter if key set, else Qubrid.
USE_MOCK_LLM=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults to localhost:5173 and localhost:8080 (Vite).
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://myapp.com
